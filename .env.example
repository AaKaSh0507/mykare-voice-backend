# ── Application ──────────────────────────────────────
ENV=
DB_PATH=

# ── LiveKit (real-time voice infrastructure) ─────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Deepgram (speech-to-text) ────────────────────────
DEEPGRAM_API_KEY=

# ── Cartesia (text-to-speech) ────────────────────────
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# ── Gemini (LLM for conversation agent) ─────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Tavus (Avatar) ───────────────────────────────────
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
# Optional if you use persona-based sessions:
TAVUS_PERSONA_ID=